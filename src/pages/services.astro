---
import Features2 from '~/components/widgets/Features2.astro';
import Hero from '~/components/widgets/Hero.astro';
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'Services',
};
---

<Layout metadata={metadata}>
  <!-- Hero Widget ******************* -->

  <Hero
    title="Tutoring Services"
    subtitle="Professional private tutition, covering all major exam boards, entrance examinations and Further Maths options."
  />

  <!-- Features2 Widget ************** -->

  <section class="bg-section-gradient">
    <Features2
      columns={3}
      classes={{ container: 'pt-2 md:pt-4 pb-8 md:pb-12' }}
      items={[
        {
          title: 'University Entrance Exams',
          description:
            'Specialist preparation for TMUA, ESAT, STEP and others. Mock interviews and Oxbridge admissions.',
          icon: 'tabler:school',
        },
        {
          title: 'A‑Level Maths & Further Maths',
          description:
            'Comprehensive support for Maths & Further Maths across all major exam boards (including Edexcel, AQA, OCR A/MEI and CIE) and all optional module choices.',
          icon: 'tabler:calculator',
        },
        {
          title: 'Undergraduate & Graduate Level',
          description:
            'Undergraduate and Graduate Mathematics and Mathematical Methods modules. Experienced tutoring STEM students at top UK and International universities.',
          icon: 'tabler:books',
        },
        {
          title: 'Scientific Computing',
          description:
            'Python, Jupyter, data science, and computational methods. Support for programming assignments, data analysis projects, and numerical methods.',
          icon: 'tabler:code',
        },
        {
          title: 'Mock Exams & Professional Marking',
          description:
            'Realistic mocks written and marked to exam‑board standards, with detailed feedback, mark schemes, and improvement plans.',
          icon: 'tabler:clipboard-check',
        },
        {
          title: 'GCSE & A-level Physics',
          description: 'Support in Physics tailored towards your needs and goals.',
          icon: 'tabler:atom',
        },
        {
          title: 'Alternative Qualifications',
          description: 'Expert tuition for IB, HND, BTEC and Foundation Year Programmes.',
          icon: 'tabler:certificate',
        },
        {
          title: 'Special Educational Needs',
          description:
            'Experienced working with students with dyslexia, ASD and ADHD, adapting teaching to individual needs.',
          icon: 'tabler:heart-handshake',
        },
        {
          title: 'Enhanced DBS Certified',
          description:
            'Enhanced DBS certification ensures a professional, secure learning environment for all students.',
          icon: 'tabler:shield-check',
        },
      ]}
    />
  </section>
</Layout>
