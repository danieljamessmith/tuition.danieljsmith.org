---
import { Icon } from 'astro-icon/components';
import Hero from '~/components/widgets/Hero.astro';
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'Services',
  description:
    'Focused online tuition for A-Level Maths, Further Maths, admissions tests, undergraduate mathematics, physics, scientific computing, and marking support.',
};

const services = [
  {
    title: 'A-Level Maths & Further Maths',
    description:
      'Structured support across major exam boards, including Edexcel, AQA, OCR A/MEI and CIE, with optional module support.',
    icon: 'tabler:calculator',
    items: [
      'Topic consolidation and problem-solving',
      'Past-paper technique and exam strategy',
      'Support for private candidates',
    ],
  },
  {
    title: 'Admissions Tests & Interviews',
    description: 'Preparation for TMUA, ESAT, STEP and related university entrance assessments.',
    icon: 'tabler:school',
    items: [
      'Timed problem-solving practice',
      'Method selection and written reasoning',
      'Oxbridge-style interview preparation',
    ],
  },
  {
    title: 'Undergraduate Mathematics',
    description:
      'Support for STEM students working through mathematical methods, applied mathematics, statistics and related modules.',
    icon: 'tabler:books',
    items: [
      'Module-specific gap filling',
      'Worked examples and revision planning',
      'Engineering and physical-science applications',
    ],
  },
  {
    title: 'Physics',
    description: 'GCSE and A-Level Physics support, with an emphasis on mathematical fluency and exam technique.',
    icon: 'tabler:atom',
    items: ['Core topic explanations', 'Calculation and modelling practice', 'Mark-scheme focused feedback'],
  },
  {
    title: 'Scientific Computing',
    description: 'Python, Jupyter, numerical methods and data-science support for technical coursework and projects.',
    icon: 'tabler:code',
    items: ['Programming concepts and debugging', 'Numerical methods and modelling', 'Data analysis workflows'],
  },
  {
    title: 'Mock Exams & Marking',
    description: 'Realistic practice papers, detailed marking and written feedback for targeted improvement.',
    icon: 'tabler:clipboard-check',
    items: ['Bespoke mock papers', 'Detailed written solutions', 'Feedback charged separately where agreed'],
  },
];
---

<Layout metadata={metadata}>
  <Hero
    title="Tutoring Services"
    subtitle="Focused online tuition for school, admissions and university mathematics, with physics and scientific computing support by arrangement."
  />

  <section class="bg-section-gradient py-8 md:py-12">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <div class="grid gap-4 md:grid-cols-2">
        {
          services.map((service) => (
            <article class="group rounded-lg border border-gray-100 bg-white p-5 shadow-card transition-all duration-300 hover:-translate-y-0.5 hover:shadow-card-hover">
              <div class="flex gap-4">
                <div class="flex-shrink-0">
                  <div class="flex h-11 w-11 items-center justify-center rounded-lg bg-emerald-50 text-emerald-700 transition-colors group-hover:bg-emerald-100">
                    <Icon name={service.icon} class="h-5 w-5" />
                  </div>
                </div>
                <div class="min-w-0">
                  <h2 class="text-xl font-bold leading-snug tracking-normal text-gray-900 transition-colors group-hover:text-emerald-700">
                    {service.title}
                  </h2>
                  <p class="mt-2 text-sm leading-relaxed text-gray-600">{service.description}</p>
                  <ul class="mt-4 space-y-2">
                    {service.items.map((item) => (
                      <li class="flex gap-2 text-sm leading-relaxed text-gray-600">
                        <Icon name="tabler:check" class="mt-0.5 h-4 w-4 flex-shrink-0 text-emerald-600" />
                        <span>{item}</span>
                      </li>
                    ))}
                  </ul>
                </div>
              </div>
            </article>
          ))
        }
      </div>

      <div class="mt-6 rounded-lg border border-emerald-100 bg-white/80 p-5 shadow-sm">
        <div class="flex flex-col gap-3 sm:flex-row sm:items-start">
          <div
            class="flex h-10 w-10 flex-shrink-0 items-center justify-center rounded-lg bg-emerald-50 text-emerald-700"
          >
            <Icon name="tabler:sparkles" class="h-5 w-5" />
          </div>
          <div>
            <h2 class="text-lg font-bold tracking-normal text-gray-900">Other qualifications and learning needs</h2>
            <p class="mt-1 text-sm leading-relaxed text-gray-600">
              GCSE, IB, HND, BTEC, Foundation Year programmes, special educational needs adaptations and other routes
              can be discussed by enquiry.
            </p>
            <a
              href="/contact"
              class="mt-3 inline-flex items-center text-sm font-semibold text-emerald-700 transition-colors hover:text-emerald-900"
            >
              Discuss tuition options
              <Icon name="tabler:arrow-right" class="ml-1.5 h-4 w-4" />
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
