---
import Hero from '~/components/widgets/Hero.astro';
import Layout from '~/layouts/PageLayout.astro';
import { policyIntro, policySections, policyTitle } from '~/data/policies';

const metadata = {
  title: 'Policies',
  description: 'Policies and terms of service for private tuition clients.',
};
---

<Layout metadata={metadata}>
  <Hero tagline="Policies" title={policyTitle} subtitle="Terms for private tuition clients." />

  <section class="bg-section-gradient py-8 md:py-12">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <div class="mx-auto max-w-5xl">
        <article class="rounded-lg border border-gray-100 bg-white p-5 shadow-card sm:p-7 lg:p-9">
          <header class="border-b border-emerald-100 pb-6">
            <p class="max-w-3xl text-lg leading-relaxed text-gray-700">{policyIntro}</p>

            <nav aria-labelledby="policy-contents-heading" class="mt-7">
              <h2 id="policy-contents-heading" class="text-sm font-bold uppercase tracking-wide text-emerald-700">
                Contents
              </h2>
              <ol class="mt-4 grid gap-x-8 gap-y-3 sm:grid-cols-2">
                {
                  policySections.map((section) => (
                    <li>
                      <a
                        href={`#${section.id}`}
                        class="flex items-baseline gap-3 text-sm font-semibold leading-snug text-gray-900 transition-colors hover:text-emerald-700"
                      >
                        <span class="shrink-0 text-emerald-700">{section.number}.</span>
                        <span>{section.title}</span>
                      </a>
                    </li>
                  ))
                }
              </ol>
            </nav>
          </header>

          <div class="mt-10 space-y-14">
            {
              policySections.map((section) => (
                <section id={section.id} class="scroll-mt-24">
                  <div class="mb-3 border-b border-gray-100 pb-4">
                    <h2 class="text-2xl font-bold leading-tight tracking-normal text-gray-900">
                      <a href={`#${section.id}`} class="transition-colors hover:text-emerald-700">
                        <span class="text-emerald-700">{section.number}.</span> {section.title}
                      </a>
                    </h2>
                  </div>

                  <ol class="divide-y divide-gray-100">
                    {section.policies.map((policy) => (
                      <li
                        id={policy.id}
                        class="scroll-mt-24 py-5 transition-colors target:rounded-lg target:bg-emerald-50 target:px-4 sm:grid sm:grid-cols-[4.25rem_minmax(0,1fr)] sm:gap-5"
                      >
                        <a
                          href={`#${policy.id}`}
                          class="mb-2 inline-flex rounded-md px-0 py-1 text-sm font-bold text-emerald-700 transition-colors hover:text-emerald-900 sm:mb-0 sm:self-start"
                          aria-label={`Policy ${policy.number}`}
                        >
                          {policy.number}
                        </a>
                        <p class="m-0 text-base leading-relaxed text-gray-700">{policy.text}</p>
                      </li>
                    ))}
                  </ol>
                </section>
              ))
            }
          </div>
        </article>
      </div>
    </div>
  </section>
</Layout>
