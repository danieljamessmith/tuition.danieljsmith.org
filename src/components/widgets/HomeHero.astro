---
import Image from '~/components/common/Image.astro';
import { Icon } from 'astro-icon/components';
---

<section class="relative md:-mt-[76px] not-prose overflow-hidden">
  <div class="absolute inset-0 bg-hero-pattern" aria-hidden="true"></div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6">
    <div class="pt-0 md:pt-[76px] pointer-events-none"></div>
    <div class="py-10 md:py-14">
      <div class="max-w-6xl mx-auto">
        <div class="flex flex-col md:flex-row md:items-center gap-8 md:gap-12">
          <!-- Headshot -->
          <div class="flex-shrink-0 mx-auto md:mx-0">
            <div class="relative">
              <div
                class="absolute -inset-2 bg-gradient-to-br from-emerald-400 to-teal-500 rounded-2xl opacity-20 blur-sm"
                aria-hidden="true"
              >
              </div>
              <Image
                src="~/assets/images/IMG_0976.JPG"
                alt="Daniel J. Smith - Mathematics and Physics Tutor"
                width={240}
                height={240}
                class="relative w-48 h-48 md:w-60 md:h-60 rounded-2xl object-cover shadow-card-lg ring-4 ring-white"
                loading="eager"
              />
            </div>
          </div>

          <!-- Hero text -->
          <div class="flex-1 text-center md:text-left">
            <h1
              class="text-3xl md:text-4xl lg:text-5xl font-bold leading-tight tracking-tight mb-4 font-heading text-gray-900"
            >
              Bespoke Mathematics <span class="italic font-light">&amp;</span> Physics Tuition
            </h1>
            <p class="text-lg md:text-xl text-muted mb-8 leading-relaxed">
              Cambridge MASt graduate with <span class="font-semibold text-emerald-700">1500+ hours'</span> experience helping
              students excel in Maths, Further Maths and Physics. Entrance exams and admissions consultation.
            </p>
            <div class="flex flex-col sm:flex-row gap-4 justify-center md:justify-start">
              <a class="btn-primary" href="/services">
                <span>View Services</span>
                <Icon name="tabler:arrow-right" class="w-4 h-4 ml-2" />
              </a>
              <a class="btn-secondary" href="/contact">Get in Touch</a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
